{
  "additionalProperties": false,
  "description": "Row schema for ``data/warehouse/dividends.csv``.\n\nOne row per (symbol, ex-date) cash dividend event. ``dps_local`` is in\nthe issuer's home currency; ``dps_krw`` is the FX-converted KRW\nequivalent the simulator credits to held lots after withholding tax.",
  "properties": {
    "date": {
      "title": "Date",
      "type": "string",
      "x-snusmic-nan-policy": "drop"
    },
    "symbol": {
      "title": "Symbol",
      "type": "string",
      "x-snusmic-nan-policy": "drop"
    },
    "dps_local": {
      "title": "Dps Local",
      "type": "number",
      "x-snusmic-nan-policy": "drop"
    },
    "source_currency": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Currency",
      "x-snusmic-nan-policy": "drop"
    },
    "dps_krw": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dps Krw",
      "x-snusmic-nan-policy": "drop"
    }
  },
  "required": [
    "date",
    "symbol",
    "dps_local"
  ],
  "title": "DividendEvent",
  "type": "object",
  "x-snusmic-table": "dividends",
  "x-snusmic-semantic-version": "1.0"
}
